# ─── App ──────────────────────────────────────────────────
NODE_ENV=development
API_PORT=3001
FRONTEND_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://damora:damora@localhost:5432/damora

# ─── Auth ─────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-this-access-secret-in-production
JWT_REFRESH_SECRET=change-this-refresh-secret-in-production
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── AI Provider (switch with 1 line) ─────────────────────
# Options: mock | gemini | openai | claude
AI_PROVIDER=mock
EMBEDDING_PROVIDER=mock

# ─── Gemini (free tier - primary for MVP) ─────────────────
GEMINI_API_KEY=

# ─── OpenAI (premium - add in Phase 3+) ──────────────────
OPENAI_API_KEY=

# ─── Anthropic (future) ───────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Storage: MinIO locally / S3 in production ────────────
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=damora
STORAGE_SECRET_KEY=damora123
STORAGE_BUCKET=damora-docs
STORAGE_USE_SSL=false
STORAGE_REGION=us-east-1

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Qdrant (Vector DB) ───────────────────────────────────
QDRANT_URL=http://localhost:6333

# ─── CORS ─────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000
